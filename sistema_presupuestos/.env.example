# Copy to .env and fill in real values. Read by docker-compose.
APP_ENV=dev
SECRET_KEY=change-me-in-prod
DATABASE_URL=postgresql+psycopg2://budget:budget@db:5432/budget

# Mail (defaults point at the mailhog service in docker-compose)
MAIL_SERVER=mailhog
MAIL_PORT=1025
MAIL_USE_TLS=0
MAIL_DEFAULT_SENDER=Estudio Sarachaga <no-reply@sarachaga.uy>

# PDF
PDF_WKHTML_PATH=/usr/bin/wkhtmltopdf
